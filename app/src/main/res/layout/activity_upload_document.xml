<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FDF4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#059669"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📤 Upload Document"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textColor="#059669"
                android:backgroundTint="#FFFFFF"
                android:textSize="12sp"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText
                    android:id="@+id/etDocTitle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Document Title"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@android:drawable/edit_text"/>

                <EditText
                    android:id="@+id/etDocCategory"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Category (Notes, Assignment...)"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:background="@android:drawable/edit_text"/>

                <Button
                    android:id="@+id/btnPickFile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="📎 Pick PDF File"
                    android:backgroundTint="#D1FAE5"
                    android:textColor="#065F46"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No file selected"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnUpload"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Upload Document ↑"
                    android:backgroundTint="#059669"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>