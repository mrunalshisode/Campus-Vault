<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#FFF1F2">

        <!-- Warning icon -->
        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="⚠️"
            android:textSize="18sp"
            android:layout_marginEnd="10dp"/>

        <!-- Student info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDefaulterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/tvDefaulterRoll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roll: 51"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvDefaulterSubjects"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low in: Math, OS"
                android:textSize="11sp"
                android:textColor="#BE123C"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Percentage -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDefaulterPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#BE123C"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="overall"
                android:textSize="10sp"
                android:textColor="#9CA3AF"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>